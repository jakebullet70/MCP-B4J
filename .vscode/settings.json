{
    "editor.fontFamily": "Comic Sans MS",
    "editor.fontSize": 14,
    "workbench.colorTheme": "Dark",
    "workbench.colorCustomizations": {},
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [
                    "comment"
                ],
                "settings": {
                    "foreground": "rgba(123, 116, 102, 0)",
                    "background": "rgba(0, 0, 0, 0.008)"
                }
            },
            {
                "scope": [
                    "variable"
                ],
                "settings": {
                    "foreground": "rgba(200, 200, 200, 0)",
                    "background": "rgba(0, 0, 0, 0.008)"
                }
            },
            {
                "scope": [
                    "constant.numeric"
                ],
                "settings": {
                    "foreground": "rgba(34, 205, 255, 0)",
                    "background": "rgba(0, 0, 0, 0.008)"
                }
            },
            {
                "scope": [
                    "keyword.operator"
                ],
                "settings": {
                    "foreground": "rgba(183, 226, 232, 0)",
                    "background": "rgba(0, 0, 0, 0.008)"
                }
            },
            {
                "scope": [
                    "string"
                ],
                "settings": {
                    "foreground": "rgba(0, 118, 236, 0)",
                    "background": "rgba(0, 0, 0, 0.008)"
                }
            },
            {
                "scope": [
                    "keyword"
                ],
                "settings": {
                    "foreground": "rgba(99, 199, 147, 0)",
                    "background": "rgba(0, 0, 0, 0.008)"
                }
            }
        ]
    },
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true
    }
}